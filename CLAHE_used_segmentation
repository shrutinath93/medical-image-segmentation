stats=True)\n        (2): ReLU(inplace=True)\n        (3): Conv2d(32, 32, kernel_size=(3, 3), stride=(1, 1), padding=(1, 1), bias=False)\n        (4): BatchNorm2d(32, eps=1e-05, momentum=0.1, affine=True, track_running_stats=True)\n        (5): ReLU(inplace=True)\n      )\n    )\n  )\n  (outc): OutConv(\n    (conv): Conv2d(32, 1, kernel_size=(1, 1), stride=(1, 1))\n  )\n)"},"metadata":{}}],"execution_count":13},{"cell_type":"code","source":"# STEP 11: GRADCAM / EIGENCAM VISUALIZATION\n# Uses the last encoder conv layer (down3) as\n# the target layer — deepest semantic features\n# No external library needed (pure PyTorch hooks)\n# ─────────────────────────────────────────────\n\nclass GradCAM:\n    \"\"\"\n    Gradient-weighted Class Activation Map for segmentation.\n    Target layer: last encoder block (down3.maxpool_conv.1)\n    For each pixel the gradient of the mean predicted probability\n    w.r.t. the feature maps is used to weight the activations.\n    \"\"\"\n    def __init__(self, model, target_layer):\n        self.model        = model\n        self.activations  = None\n        self.gradients    = None\n        self._fwd_hook    = target_layer.register_forward_hook(self._save_activation)\n        self._bwd_hook    = target_layer.register_full_backward_hook(self._save_gradient)\n\n    def _save_activation(self, module, inp, out):\n        self.activations = out.detach()\n\n    def _save_gradient(self, module, grad_in, grad_out):\n        self.gradients = grad_out[0].detach()\n\n    def generate(self, img_tensor):\n        \"\"\"\n        img_tensor : (1, C, H, W) on device\n        Returns    : (H, W) numpy array in [0, 1]\n        \"\"\"\n        self.model.zero_grad()\n        logits = self.model(img_tensor)\n        # Score = mean of sigmoid predictions (segmentation proxy)\n        score  = torch.sigmoid(logits).mean()\n        score.backward()\n\n        # Global average pool gradients over spatial dims\n        weights = self.gradients.mean(dim=[2, 3], keepdim=True)  # (1, C, 1, 1)\n        cam     = (weights * self.activations).sum(dim=1).squeeze()  # (H', W')\n        cam     = torch.relu(cam).cpu().numpy()\n\n        # Resize to input spatial size\n        cam = cv2.resize(cam, (img_tensor.shape[3], img_tensor.shape[2]))\n        if cam.max() > 0:\n            cam = (cam - cam.min()) / (cam.max() - cam.min())\n        return cam\n\n    def remove_hooks(self):\n        self._fwd_hook.remove()\n        self._bwd_hook.remove()\n\n\ndef plot_gradcam(indices, title, filename, dataset_obj):\n    \"\"\"\n    For each sample plots:\n    Col 0: Original image\n    Col 1: Ground truth mask\n    Col 2: Predicted mask  (Dice + IoU)\n    Col 3: GradCAM heatmap (what the model focused on)\n    Col 4: GradCAM overlay on image\n    \"\"\"\n    # Register GradCAM on last encoder layer\n    target_layer = best_model.down3.maxpool_conv[1].double_conv\n    gradcam      = GradCAM(best_model, target_layer)\n\n    n    = len(indices)\n    fig, axes = plt.subplots(n, 5, figsize=(22, 4 * n))\n    fig.suptitle(title, fontsize=14, fontweight='bold')\n    if n == 1:\n        axes = [axes]\n\n    for row, idx in enumerate(indices):\n        img_t, mask_t = dataset_obj[idx]\n        inp = img_t.unsqueeze(0).to(device)\n\n        # GradCAM needs gradients\n        best_model.eval()\n        cam = gradcam.generate(inp)\n\n        with torch.no_grad():\n            with torch.amp.autocast(device_type):\n                logits = best_model(inp)\n\n        m    = compute_all_metrics(logits.cpu(), mask_t)\n        orig = denormalize(img_t)\n\n        # Col 0: Original\n        axes[row][0].imshow(orig)\n        axes[row][0].set_title(f\"Sample {idx}\\nOriginal Scan\", fontsize=9)\n        axes[row][0].axis('off')\n\n        # Col 1: Ground truth\n        axes[row][1].imshow(m['true'], cmap='gray')\n        axes[row][1].set_title(\"Ground Truth Mask\", fontsize=9)\n        axes[row][1].axis('off')\n\n        # Col 2: Prediction\n        axes[row][2].imshow(m['pred_bin'], cmap='gray')\n        axes[row][2].set_title(f\"Prediction\\nDice:{m['dice']:.3f}  IoU:{m['iou']:.3f}\", fontsize=9)\n        axes[row][2].axis('off')\n\n        # Col 3: GradCAM heatmap\n        hm = axes[row][3].imshow(cam, cmap=heat_cmap, vmin=0, vmax=1)\n        axes[row][3].set_title(f\"GradCAM\\n(Feature Importance)\", fontsize=9)\n        axes[row][3].axis('off')\n        plt.colorbar(hm, ax=axes[row][3], fraction=0.046, pad=0.04)\n\n        # Col 4: GradCAM blended onto original image\n        cam_rgb     = plt.cm.jet(cam)[:, :, :3]          # (H,W,3)  jet colourmap\n        blend       = 0.55 * orig + 0.45 * cam_rgb       # alpha blend\n        blend       = np.clip(blend, 0, 1)\n        axes[row][4].imshow(blend)\n        axes[row][4].set_title(f\"GradCAM Overlay\\nSens:{m['sensitivity']:.3f}  Prec:{m['precision']:.3f}\", fontsize=9)\n        axes[row][4].axis('off')\n\n    plt.tight_layout()\n    plt.savefig(filename, dpi=150, bbox_inches='tight')\n    plt.show()\n    gradcam.remove_hooks()\n    print(f\"  ✅ Saved: {filename}\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-07T09:09:10.814925Z","iopub.execute_input":"2026-06-07T09:09:10.815258Z","iopub.status.idle":"2026-06-07T09:09:10.833108Z","shell.execute_reply.started":"2026-06-07T09:09:10.815233Z","shell.execute_reply":"2026-06-07T09:09:10.832408Z"}},"outputs":[],"execution_count":14},{"cell_type":"code","source":"# STEP 12: TEST OVERLAY VISUALIZATION\n# Shows prediction boundary overlaid on image\n# Green  = Ground truth boundary\n# Red    = Predicted region (filled)\n# Yellow = Overlap (correct region)\n# ─────────────────────────────────────────────\n\ndef plot_test_overlay(indices, title, filename, dataset_obj):\n    \"\"\"\n    For each sample shows a detailed 6-panel overlay:\n    Col 0: Original image\n    Col 1: Ground truth mask\n    Col 2: Predicted mask\n    Col 3: Confidence heatmap\n    Col 4: Overlay (pred=red fill, GT=green boundary, overlap=yellow)\n    Col 5: Error map (FP=blue, FN=orange)\n    \"\"\"\n    n    = len(indices)\n    fig, axes = plt.subplots(n, 6, figsize=(26, 4 * n))\n    fig.suptitle(title, fontsize=14, fontweight='bold')\n    if n == 1:\n        axes = [axes]\n\n    for row, idx in enumerate(indices):\n        img_t, mask_t = dataset_obj[idx]\n        with torch.no_grad():\n            with torch.amp.autocast(device_type):\n                logits = best_model(img_t.unsqueeze(0).to(device))\n\n        m    = compute_all_metrics(logits.cpu(), mask_t)\n        orig = denormalize(img_t)\n\n        # -- boundaries for overlay --\n        gt_dil  = ndimage.binary_dilation(m['true'].astype(bool),     iterations=2)\n        gt_ero  = ndimage.binary_erosion(m['true'].astype(bool),      iterations=2)\n        gt_bnd  = np.clip(gt_dil.astype(float) - gt_ero.astype(float), 0, 1)\n\n        pr_dil  = ndimage.binary_dilation(m['pred_bin'].astype(bool), iterations=2)\n        pr_ero  = ndimage.binary_erosion(m['pred_bin'].astype(bool),  iterations=2)\n        pr_bnd  = np.clip(pr_dil.astype(float) - pr_ero.astype(float), 0, 1)\n\n        overlap = (m['true'] * m['pred_bin'])          # both agree → correct\n        fp      = (m['pred_bin'] * (1 - m['true']))    # predicted but not GT\n        fn      = ((1 - m['pred_bin']) * m['true'])    # GT but not predicted\n\n        # Col 0: Original\n        axes[row][0].imshow(orig)\n        axes[row][0].set_title(f\"Sample {idx}\\nOriginal Scan\", fontsize=9)\n        axes[row][0].axis('off')\n\n        # Col 1: Ground truth\n        axes[row][1].imshow(m['true'], cmap='gray')\n        axes[row][1].set_title(\"Ground Truth\", fontsize=9)\n        axes[row][1].axis('off')\n\n        # Col 2: Prediction\n        axes[row][2].imshow(m['pred_bin'], cmap='gray')\n        axes[row][2].set_title(f\"Prediction\\nDice:{m['dice']:.3f}\", fontsize=9)\n        axes[row][2].axis('off')\n\n        # Col 3: Confidence heatmap\n        hm = axes[row][3].imshow(m['prob'], cmap=heat_cmap, vmin=0, vmax=1)\n        axes[row][3].set_title(f\"Confidence Map\\nIoU:{m['iou']:.3f}\", fontsize=9)\n        axes[row][3].axis('off')\n        plt.colorbar(hm, ax=axes[row][3], fraction=0.046, pad=0.04)\n\n        # Col 4: Overlay — red pred fill, green GT boundary, yellow overlap\n        ov = orig.copy()\n        # Red fill for prediction\n        ov[:, :, 0] = np.clip(ov[:, :, 0] + m['pred_bin'] * 0.35, 0, 1)\n        ov[:, :, 1] = np.clip(ov[:, :, 1] - m['pred_bin'] * 0.15, 0, 1)\n        ov[:, :, 2] = np.clip(ov[:, :, 2] - m['pred_bin'] * 0.15, 0, 1)\n        # Yellow for overlap\n        ov[:, :, 0] = np.clip(ov[:, :, 0] + overlap * 0.3, 0, 1)\n        ov[:, :, 1] = np.clip(ov[:, :, 1] + overlap * 0.3, 0, 1)\n        # Green GT boundary\n        ov[:, :, 1] = np.clip(ov[:, :, 1] + gt_bnd * 0.8, 0, 1)\n        ov[:, :, 0] = np.clip(ov[:, :, 0] - gt_bnd * 0.3, 0, 1)\n        axes[row][4].imshow(ov)\n        axes[row][4].set_title(\"Overlay\\n🔴Pred 🟢GT-bnd 🟡Overlap\", fontsize=9)\n        axes[row][4].axis('off')\n\n        # Col 5: Error map — FP=blue, FN=orange\n        err = np.zeros((*m['true'].shape, 3))\n        err[:, :, 2] = fp           # blue  = False Positive\n        err[:, :, 0] = fn * 1.0    # red channel\n        err[:, :, 1] = fn * 0.5    # → orange = False Negative\n        axes[row][5].imshow(np.clip(err, 0, 1))\n        axes[row][5].set_title(\"Error Map\\n🔵FP (over-pred)  🟠FN (missed)\", fontsize=9)\n        axes[row][5].axis('off')\n\n    plt.tight_layout()\n    plt.savefig(filename, dpi=150, bbox_inches='tight')\n    plt.show()\n    print(f\"  ✅ Saved: {filename}\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-07T09:09:10.834221Z","iopub.execute_input":"2026-06-07T09:09:10.834699Z","iopub.status.idle":"2026-06-07T09:09:10.859506Z","shell.execute_reply.started":"2026-06-07T09:09:10.834672Z","shell.execute_reply":"2026-06-07T09:09:10.858635Z"}},"outputs":[],"execution_count":15},{"cell_type"